#!/bin/sh
mount -t proc proc /proc
mount -t sysfs sysfs /sys
mount -t devtmpfs dev /dev

hostname rezzos
echo 0 > /proc/sys/kernel/printk

# Create user
if ! grep -q "^user:" /etc/passwd 2>/dev/null; then
    echo "user:x:1000:1000:User:/home/user:/bin/sh" >> /etc/passwd
    mkdir -p /home/user
fi

ifconfig lo 127.0.0.1 up
ifconfig eth0 10.0.2.15 netmask 255.255.255.0 up
route add default gw 10.0.2.2
echo "nameserver 8.8.8.8" > /etc/resolv.conf

mount /dev/vda /mnt/disk 2>/dev/null

# Restore packages from disk
if [ -d /mnt/disk/packages ]; then
    for pkg in /mnt/disk/packages/*.apk; do
        [ -f "$pkg" ] || continue
        cd /tmp && mkdir -p /tmp/pkg && cd /tmp/pkg
        tar -xzf "$pkg" 2>/dev/null
        cp -r usr/* /usr/ 2>/dev/null
        cp -r bin/* /bin/ 2>/dev/null
        cp -r lib/* /lib/ 2>/dev/null
        rm -rf /tmp/pkg
    done
    cd /
fi

clear
echo ""

exec runsvdir /etc/runit/runsvdir/default
